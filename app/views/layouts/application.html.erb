<!DOCTYPE html>
<html>
  <head>
    <title>BillsAgent</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="navbar">
      <div class="navbar-inner">
        <%= link_to "BillsAgent", root_path, class: "navbar-brand" %>

        <div class="navbar-links">
          <% if user_signed_in? %>
            <%= link_to "Dashboard", uploads_path, class: "navbar-link" %>
            <%= link_to "New Upload", new_upload_path, class: "navbar-link navbar-link-pill" %>

            <%= form_with url: destroy_user_session_path, method: :delete, local: true, html: { class: "navbar-signout-form" } do %>
              <button type="submit" class="navbar-link-button">Sign Out</button>
            <% end %>
          <% else %>
            <%= link_to "Sign In", new_user_session_path, class: "navbar-link" %>
            <%= link_to "Register", new_user_registration_path, class: "navbar-link navbar-link-pill" %>
          <% end %>
        </div>
      </div>
    </nav>

    <% if notice %>
      <div class="flash-wrap">
        <div class="alert alert-success"><%= notice %></div>
      </div>
    <% end %>

    <% if alert %>
      <div class="flash-wrap">
        <div class="alert alert-error"><%= alert %></div>
      </div>
    <% end %>

    <%= yield %>
  </body>
</html>