<div class="page-container">
  <h1 class="page-title">Bills & Subscriptions Agent</h1>
  <p class="page-subtitle">
    Review parsed transactions, detected subscriptions, and manual corrections.
  </p>

  <% if notice %>
    <div class="alert alert-success"><%= notice %></div>
  <% end %>

  <% if alert %>
    <div class="alert alert-error"><%= alert %></div>
  <% end %>

  <div class="section-card">
    <div class="section-header">
      <div>
        <h2 class="section-title">Upload Details</h2>
        <p class="section-note">Analyze your uploaded file and inspect the extracted rows.</p>
      </div>
    </div>

    <% if @upload.file.attached? %>
      <div class="file-meta">
        <div class="meta-pill">
          <strong>Filename:</strong> <%= @upload.file.filename %>
        </div>
        <div class="meta-pill">
          <strong>Type:</strong> <%= @upload.file.content_type || "Unknown" %>
        </div>
      </div>

      <div class="button-row">
        <%= button_to "Run Analysis", analyze_upload_path(@upload), method: :post %>
        <%= button_to "Recalculate from Edited Rows", recalculate_upload_path(@upload), method: :post, class: "btn-secondary" %>
        <%= link_to "Upload another file", root_path, class: "btn-link" %>
      </div>
    <% else %>
      <p class="empty-state">No file attached.</p>
    <% end %>
  </div>

  <% if @upload.analysis_result.present? %>
    <% subscriptions = @upload.analysis_result["subscriptions"] || [] %>
    <% needs_review = @upload.analysis_result["needs_review"] || [] %>
    <% parsed_rows = @upload.analysis_result["parsed_rows"] || [] %>
    <% row_count = @upload.analysis_result["row_count"] || 0 %>

    <% monthly_total = subscriptions.select { |s| s["frequency"] == "monthly" }.sum { |s| s["avg_amount"].to_f } %>
    <% highest_subscription = subscriptions.max_by { |s| s["avg_amount"].to_f } %>
    <% next_upcoming = subscriptions.select { |s| s["next_expected"].present? }.min_by { |s| s["next_expected"] } %>

    <div class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Summary</h2>
          <p class="section-note">High-level metrics from the latest analysis.</p>
        </div>
      </div>

      <div class="summary-grid">
        <div class="summary-card">
          <div class="summary-label">Parsed Rows</div>
          <div class="summary-value"><%= row_count %></div>
          <div class="summary-subtext">Transactions extracted from the file</div>
        </div>

        <div class="summary-card">
          <div class="summary-label">Detected Subscriptions</div>
          <div class="summary-value"><%= subscriptions.length %></div>
          <div class="summary-subtext">Recurring items identified by the agent</div>
        </div>

        <div class="summary-card">
          <div class="summary-label">Estimated Monthly Total</div>
          <div class="summary-value">$<%= "%.2f" % monthly_total %></div>
          <div class="summary-subtext">Sum of monthly recurring charges</div>
        </div>

        <div class="summary-card">
          <div class="summary-label">Highest Subscription</div>
          <% if highest_subscription %>
            <div class="summary-value">$<%= "%.2f" % highest_subscription["avg_amount"].to_f %></div>
            <div class="summary-subtext"><%= highest_subscription["merchant"] %></div>
          <% else %>
            <div class="summary-value">—</div>
            <div class="summary-subtext">No subscription found</div>
          <% end %>
        </div>

        <div class="summary-card">
          <div class="summary-label">Next Upcoming Charge</div>
          <% if next_upcoming %>
            <div class="summary-value"><%= next_upcoming["next_expected"] %></div>
            <div class="summary-subtext"><%= next_upcoming["merchant"] %></div>
          <% else %>
            <div class="summary-value">—</div>
            <div class="summary-subtext">No upcoming charge available</div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Detected Subscriptions</h2>
          <p class="section-note">High-confidence recurring charges identified by the agent.</p>
        </div>
      </div>

      <% if subscriptions.any? %>
        <div class="table-wrap">
          <table class="modern-table">
            <thead>
              <tr>
                <th>Merchant</th>
                <th>Normalized</th>
                <th>Frequency</th>
                <th>Avg Amount</th>
                <th>Last Paid</th>
                <th>Next Expected</th>
                <th>Confidence</th>
                <th>Evidence</th>
              </tr>
            </thead>
            <tbody>
              <% subscriptions.each do |sub| %>
                <tr>
                  <td><strong><%= sub["merchant"] %></strong></td>
                  <td><%= sub["merchant_normalized"] %></td>
                  <td><span class="badge badge-blue"><%= sub["frequency"] %></span></td>
                  <td>$<%= "%.2f" % sub["avg_amount"].to_f %></td>
                  <td><%= sub["last_paid"] %></td>
                  <td><%= sub["next_expected"] %></td>
                  <td>
                    <% confidence = sub["confidence"].to_f %>
                    <% badge_class =
                      if confidence >= 0.85
                        "badge-green"
                      elsif confidence >= 0.7
                        "badge-yellow"
                      else
                        "badge-red"
                      end
                    %>
                    <span class="badge <%= badge_class %>"><%= sub["confidence"] %></span>
                  </td>
                  <td class="small-text"><%= sub["evidence"] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="empty-state">No subscriptions detected yet.</p>
      <% end %>
    </div>

    <div class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Needs Review</h2>
          <p class="section-note">Lower-confidence recurring candidates that may need manual correction.</p>
        </div>
      </div>

      <% if needs_review.any? %>
        <div class="table-wrap">
          <table class="modern-table">
            <thead>
              <tr>
                <th>Merchant</th>
                <th>Normalized</th>
                <th>Frequency</th>
                <th>Avg Amount</th>
                <th>Last Paid</th>
                <th>Next Expected</th>
                <th>Confidence</th>
                <th>Evidence</th>
              </tr>
            </thead>
            <tbody>
              <% needs_review.each do |sub| %>
                <tr>
                  <td><strong><%= sub["merchant"] %></strong></td>
                  <td><%= sub["merchant_normalized"] %></td>
                  <td><span class="badge badge-blue"><%= sub["frequency"] %></span></td>
                  <td>$<%= "%.2f" % sub["avg_amount"].to_f %></td>
                  <td><%= sub["last_paid"] %></td>
                  <td><%= sub["next_expected"] %></td>
                  <td><span class="badge badge-red"><%= sub["confidence"] %></span></td>
                  <td class="small-text"><%= sub["evidence"] %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="empty-state">No low-confidence items.</p>
      <% end %>
    </div>

    <div class="section-card">
      <div class="section-header">
        <div>
          <h2 class="section-title">Parsed Transactions</h2>
          <p class="section-note">Review extracted rows and manually correct normalized merchant names.</p>
        </div>
      </div>

      <% if parsed_rows.any? %>
        <div class="table-wrap">
          <table class="modern-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>Merchant</th>
                <th>Normalized Merchant</th>
                <th>Amount</th>
                <th>Currency</th>
              </tr>
            </thead>
            <tbody>
              <% parsed_rows.each_with_index do |row, index| %>
                <tr>
                  <td><%= row["date"] %></td>
                  <td><strong><%= row["merchant"] %></strong></td>
                  <td>
                    <%= form_with url: update_parsed_row_path(@upload, index), method: :patch, local: true, html: { class: "inline-form" } do |form| %>
                      <%= form.text_field :merchant_normalized, value: row["merchant_normalized"] %>
                      <%= form.submit "Save" %>
                    <% end %>
                  </td>
                  <td>$<%= "%.2f" % row["amount"].to_f %></td>
                  <td><%= row["currency"] || "-" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p class="empty-state">No parsed transactions found.</p>
      <% end %>
    </div>
  <% end %>
</div>