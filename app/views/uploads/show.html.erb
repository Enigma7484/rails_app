<div class="page-container">
  <% subscriptions = (@upload.analysis_result || {})["subscriptions"] || [] %>
  <% needs_review = (@upload.analysis_result || {})["needs_review"] || [] %>
  <% parsed_rows = (@upload.analysis_result || {})["parsed_rows"] || [] %>
  <% row_count = (@upload.analysis_result || {})["row_count"] || 0 %>
  <% monthly_total = subscriptions.select { |s| s["frequency"] == "monthly" }.sum { |s| s["avg_amount"].to_f } %>
  <% highest_subscription = subscriptions.max_by { |s| s["avg_amount"].to_f } %>
  <% next_upcoming = subscriptions.select { |s| s["next_expected"].present? }.min_by { |s| s["next_expected"] } %>

  <div class="page-topbar">
    <div>
      <h1 class="page-title">Upload Analysis</h1>
      <p class="page-subtitle">
        Review extracted rows, correct merchant normalization, and manage recurring subscription results.
      </p>
    </div>

    <div class="inline-actions">
      <%= link_to "Back to Dashboard", uploads_path, class: "btn btn-secondary" %>
      <%= link_to "New Upload", new_upload_path, class: "btn" %>
    </div>
  </div>

  <div class="section-card">
    <div class="section-header">
      <div>
        <h2 class="section-title">File Overview</h2>
        <p class="section-note">This upload is the source for the current analysis and export actions.</p>
      </div>
    </div>

    <div class="file-meta">
      <div class="meta-pill"><strong>Filename:</strong> <%= @upload.file.attached? ? @upload.file.filename.to_s : "No file" %></div>
      <div class="meta-pill"><strong>Content Type:</strong> <%= @upload.file&.content_type || "Unknown" %></div>
      <div class="meta-pill"><strong>Upload ID:</strong> <%= @upload.id %></div>
      <div class="meta-pill"><strong>Created:</strong> <%= @upload.created_at.strftime("%Y-%m-%d %H:%M") %></div>
    </div>

    <div class="button-row">
      <%= button_to "Run Analysis", analyze_upload_path(@upload), method: :post %>
      <%= button_to "Recalculate from Edited Rows", recalculate_upload_path(@upload), method: :post, class: "btn btn-secondary" %>
      <%= button_to "Enrich with AI", enrich_subscriptions_path(@upload), method: :post, class: "btn btn-secondary" %>
      <%= link_to "Export CSV", export_subscriptions_csv_path(@upload), class: "btn btn-secondary" %>
      <%= link_to "Export Calendar (.ics)", export_calendar_path(@upload), class: "btn btn-secondary" %>
    </div>
  </div>

  <div class="kpi-row">
    <div class="kpi-card">
      <div class="kpi-title">Parsed Rows</div>
      <div class="kpi-value"><%= row_count %></div>
      <div class="kpi-subtext">Transactions extracted from the uploaded file.</div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">Detected Subscriptions</div>
      <div class="kpi-value"><%= subscriptions.length %></div>
      <div class="kpi-subtext">Recurring charges currently identified.</div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">Monthly Total</div>
      <div class="kpi-value">$<%= "%.2f" % monthly_total %></div>
      <div class="kpi-subtext">Estimated monthly recurring spend.</div>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">Highest Subscription</div>
      <% if highest_subscription %>
        <div class="kpi-value">$<%= "%.2f" % highest_subscription["avg_amount"].to_f %></div>
        <div class="kpi-subtext"><%= highest_subscription["merchant"] %></div>
      <% else %>
        <div class="kpi-value">—</div>
        <div class="kpi-subtext">No subscription detected yet.</div>
      <% end %>
    </div>

    <div class="kpi-card">
      <div class="kpi-title">Next Upcoming Charge</div>
      <% if next_upcoming %>
        <div class="kpi-value"><%= next_upcoming["next_expected"] %></div>
        <div class="kpi-subtext"><%= next_upcoming["merchant"] %></div>
      <% else %>
        <div class="kpi-value">—</div>
        <div class="kpi-subtext">No upcoming charge available.</div>
      <% end %>
    </div>
  </div>

  <div class="section-card">
    <div class="table-section-title">
      <div>
        <h2 class="section-title">Detected Subscriptions</h2>
        <p class="section-note">High-confidence recurring charges identified by the agent.</p>
      </div>
      <div class="pill-row">
        <span class="soft-pill"><%= subscriptions.length %> detected</span>
        <span class="soft-pill">$<%= "%.2f" % monthly_total %> monthly</span>
      </div>
    </div>

    <% if subscriptions.any? %>
      <div class="table-wrap">
        <table class="modern-table">
          <thead>
            <tr>
              <th>Merchant</th>
              <th>Category</th>
              <th>Frequency</th>
              <th>Avg Amount</th>
              <th>Last Paid</th>
              <th>Next Expected</th>
              <th>Confidence</th>
              <th>Description</th>
            </tr>
          </thead>
          <tbody>
            <% subscriptions.each do |sub| %>
              <tr>
                <td class="merchant-cell">
                  <strong><%= sub["merchant"] %></strong>
                  <div class="merchant-meta"><%= sub["merchant_normalized"] %></div>
                </td>
                <td><%= sub["category"] || "-" %></td>
                <td><span class="badge badge-blue"><%= sub["frequency"] %></span></td>
                <td>$<%= "%.2f" % sub["avg_amount"].to_f %></td>
                <td><%= sub["last_paid"] %></td>
                <td><%= sub["next_expected"] %></td>
                <td>
                  <% confidence = sub["confidence"].to_f %>
                  <% badge_class =
                    if confidence >= 0.85
                      "badge-green"
                    elsif confidence >= 0.7
                      "badge-yellow"
                    else
                      "badge-red"
                    end
                  %>
                  <span class="badge <%= badge_class %>"><%= sub["confidence"] %></span>
                </td>
                <td class="small-text">
                  <div><%= sub["description"] || "-" %></div>
                  <div class="merchant-meta" style="margin-top:6px;"><%= sub["evidence"] %></div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="note-box">
        No subscriptions detected yet. Try running analysis, correcting normalized merchants, then recalculate.
      </div>
    <% end %>
  </div>

  <div class="section-card">
    <div class="table-section-title">
      <div>
        <h2 class="section-title">Needs Review</h2>
        <p class="section-note">Lower-confidence recurring candidates that may improve after manual correction.</p>
      </div>
      <div class="pill-row">
        <span class="soft-pill"><%= needs_review.length %> review items</span>
      </div>
    </div>

    <% if needs_review.any? %>
      <div class="table-wrap">
        <table class="modern-table">
          <thead>
            <tr>
              <th>Merchant</th>
              <th>Frequency</th>
              <th>Avg Amount</th>
              <th>Last Paid</th>
              <th>Next Expected</th>
              <th>Confidence</th>
              <th>Evidence</th>
            </tr>
          </thead>
          <tbody>
            <% needs_review.each do |sub| %>
              <tr>
                <td class="merchant-cell">
                  <strong><%= sub["merchant"] %></strong>
                  <div class="merchant-meta"><%= sub["merchant_normalized"] %></div>
                </td>
                <td><span class="badge badge-blue"><%= sub["frequency"] %></span></td>
                <td>$<%= "%.2f" % sub["avg_amount"].to_f %></td>
                <td><%= sub["last_paid"] %></td>
                <td><%= sub["next_expected"] %></td>
                <td><span class="badge badge-red"><%= sub["confidence"] %></span></td>
                <td class="small-text"><%= sub["evidence"] %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="note-box">
        No low-confidence items right now.
      </div>
    <% end %>
  </div>

  <div class="section-card">
    <div class="table-section-title">
      <div>
        <h2 class="section-title">Parsed Transactions</h2>
        <p class="section-note">Edit normalized merchant names, save them, then recalculate the analysis.</p>
      </div>
      <div class="pill-row">
        <span class="soft-pill"><%= row_count %> parsed rows</span>
      </div>
    </div>

    <% if parsed_rows.any? %>
      <div class="note-box" style="margin-bottom:16px;">
        Tip: unify merchant variants like <span class="metric-highlight">rogers cable</span> and
        <span class="metric-highlight">rogers</span> into the same normalized name, then click
        <strong>Recalculate from Edited Rows</strong>.
      </div>

      <div class="table-wrap">
        <table class="modern-table">
          <thead>
            <tr>
              <th>Date</th>
              <th>Merchant</th>
              <th>Normalized Merchant</th>
              <th>Amount</th>
              <th>Currency</th>
            </tr>
          </thead>
          <tbody>
            <% parsed_rows.each_with_index do |row, index| %>
              <tr>
                <td><%= row["date"] %></td>
                <td class="merchant-cell">
                  <strong><%= row["merchant"] %></strong>
                </td>
                <td>
                  <%= form_with url: update_parsed_row_path(@upload, index), method: :patch, local: true, html: { class: "inline-form" } do |form| %>
                    <%= form.text_field :merchant_normalized, value: row["merchant_normalized"] %>
                    <%= form.submit "Save" %>
                  <% end %>
                </td>
                <td>$<%= "%.2f" % row["amount"].to_f %></td>
                <td><%= row["currency"] || "-" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="note-box">
        No parsed transactions found yet. Run analysis first.
      </div>
    <% end %>
  </div>
</div>